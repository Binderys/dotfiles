# --- tmux + claude persistence (2026-04-25) -----------------------------------
# cct <name>: attach to tmux session "<name>" running claude, or create one.
# Default name is "main". Convention: `cct main` for main checkout, `cct <slug>`
# for §12 worktree sessions.
# `command` bypasses the oh-my-zsh tmux plugin alias (`_zsh_tmux_plugin_run`).
cct() {
  local name="${1:-main}"
  command tmux new-session -As "$name" claude
}
# --- end tmux + claude persistence -------------------------------------------

# --- pj: per-project tmux sessions (2026-04-25) -------------------------------
# pj <name>: attach to tmux session "<name>" with cwd ~/Project/<name>, or
# create one. pj (no arg): list current tmux sessions.
pj() {
  if [[ $# -eq 0 ]]; then
    command tmux ls 2>/dev/null || echo "no tmux sessions"
    return 0
  fi
  local name="$1"
  local dir="$HOME/Project/$name"
  if [[ ! -d "$dir" ]]; then
    echo "pj: $dir does not exist" >&2
    return 1
  fi
  command tmux new-session -As "$name" -c "$dir"
}
_pj() { compadd -- ${HOME}/Project/*(/N:t) }
compdef _pj pj
# --- end pj -------------------------------------------------------------------

